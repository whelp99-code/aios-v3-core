{
  "name": "@aios/lightrag",
  "version": "1.0.0",
  "description": "LightRAG integration for AIOS - Graph-based RAG with LM Studio embeddings",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "server": "cd server && python -m uvicorn main:app --host 0.0.0.0 --port 8000 --reload",
    "docker:build": "docker build -t lightrag-server -f Dockerfile .",
    "docker:run": "docker run -p 8000:8000 lightrag-server",
    "typecheck": "tsc --noEmit"
  },
  "license": "MIT",
  "dependencies": {
    "axios": "^1.6.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0"
  }
}
