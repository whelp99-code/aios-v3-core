generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// canonical data model — normalized operational data
model MailThread {
  id            String   @id @default(cuid())
  sourceSystem  String
  externalId    String
  subject       String
  participants  Json     // normalized email addresses
  status        String   @default("ingested") // ingested | analyzed | promoted
  metadata      Json?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  messages      MailMessage[]
  candidates    ProjectCandidate[]

  @@unique([sourceSystem, externalId])
  @@index([status])
  @@index([createdAt])
}

model MailMessage {
  id            String   @id @default(cuid())
  threadId      String
  thread        MailThread @relation(fields: [threadId], references: [id])
  externalId    String
  sender        String
  recipients    Json
  subject       String
  bodyPreview   String
  sentAt        DateTime
  attachments   Json?    // attachment references (not binary)
  metadata      Json?
  createdAt     DateTime @default(now())

  @@unique([threadId, externalId])
  @@index([sentAt])
}

model Organization {
  id            String   @id @default(cuid())
  name          String
  domain        String?  @unique
  type          String   @default("customer") // customer | partner | vendor
  metadata      Json?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  contacts      Contact[]
  projects      Project[]
  products      CustomerProduct[]
  maintenanceCases MaintenanceCase[]
  solutionProposals SolutionProposal[]

  @@index([domain])
  @@index([type])
}

model Contact {
  id            String   @id @default(cuid())
  organizationId String
  organization  Organization @relation(fields: [organizationId], references: [id])
  name          String
  email         String
  role          String?
  metadata      Json?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([organizationId, email])
  @@index([email])
}

model ProjectCandidate {
  id            String   @id @default(cuid())
  threadId      String   @unique
  thread        MailThread @relation(fields: [threadId], references: [id])
  customerId    String?
  confidence    Float    @default(0)
  status        String   @default("proposed") // proposed | needs_review | approved | rejected
  metadata      Json?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  projects      Project[]

  @@index([status])
  @@index([confidence])
}

model Project {
  id            String   @id @default(cuid())
  name          String
  customerId    String?
  customer      Organization? @relation(fields: [customerId], references: [id])
  candidateId   String?  @unique
  candidate     ProjectCandidate? @relation(fields: [candidateId], references: [id])
  status        String   @default("candidate") // candidate | active | completed | rejected
  owner         String?
  dueDate       DateTime?
  metadata      Json?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tasks         TaskCard[]
  approvals     ApprovalRequest[]
  estimates     Estimate[]
  proposals     Proposal[]
  pocPlans      PocPlan[]
  emailDrafts   EmailDraft[]
  cfoHandoffs   CfoHandoff[]
  products      CustomerProduct[]

  @@index([status])
  @@index([customerId])
}

model TaskCard {
  id            String   @id @default(cuid())
  projectId     String
  project       Project @relation(fields: [projectId], references: [id])
  title         String
  description   String?
  status        String   @default("pending") // pending | in_progress | done
  assignee      String?
  dueDate       DateTime?
  metadata      Json?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([projectId, status])
}

model ApprovalRequest {
  id            String   @id @default(cuid())
  projectId     String
  project       Project @relation(fields: [projectId], references: [id])
  type          String   @default("general") // general | external_send | budget
  status        String   @default("pending") // pending | approved | rejected
  requestedBy   String
  decidedBy     String?
  decidedAt     DateTime?
  reason        String?
  metadata      Json?
  actionType    String?
  actionTarget  String?
  actionPayload Json?
  payloadHash   String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  decision      ApprovalDecision?
  outbox        ExternalActionOutbox?

  @@index([status])
  @@index([projectId])
}

model ApprovalDecision {
  id            String   @id @default(cuid())
  approvalId    String   @unique
  approval      ApprovalRequest @relation(fields: [approvalId], references: [id])
  decision      String
  actorId       String
  reason        String?
  decidedAt     DateTime
  createdAt     DateTime @default(now())
}

model ExternalActionOutbox {
  id            String   @id @default(cuid())
  approvalId    String   @unique
  approval      ApprovalRequest @relation(fields: [approvalId], references: [id])
  projectId     String
  actionType    String
  target        String
  payload       Json
  payloadHash   String
  status        String   @default("pending")
  attempts      Int      @default(0)
  lastError     String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([status, createdAt])
  @@index([projectId])
}

model AuditEvent {
  id            String   @id @default(cuid())
  aggregateType String
  aggregateId   String
  eventType     String
  actorId       String?
  data          Json?
  createdAt     DateTime @default(now())

  @@index([aggregateType, aggregateId])
  @@index([createdAt])
}

model Estimate {
  id           String   @id
  projectId    String
  project      Project  @relation(fields: [projectId], references: [id])
  projectName  String
  customerName String
  items        Json
  subtotal     Decimal  @db.Decimal(18, 4)
  tax          Decimal  @db.Decimal(18, 4)
  total        Decimal  @db.Decimal(18, 4)
  currency     String
  validUntil   DateTime
  status       String   @default("draft")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([projectId, status])
}

model Proposal {
  id           String   @id
  projectId    String
  project      Project  @relation(fields: [projectId], references: [id])
  projectName  String
  customerName String
  sections     Json
  status       String   @default("draft")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([projectId, status])
}

model PocPlan {
  id              String   @id
  projectId       String
  project         Project  @relation(fields: [projectId], references: [id])
  objectives      Json
  scope           String
  timeline        Json
  successCriteria Json
  status          String   @default("draft")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([projectId, status])
}

model EmailDraft {
  id             String   @id
  projectId      String
  project        Project  @relation(fields: [projectId], references: [id])
  recipientEmail String
  subject        String
  body           String
  purpose        String
  status         String   @default("draft")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([projectId, status])
}

model CfoHandoff {
  id          String   @id
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id])
  items       Json
  totalAmount Decimal  @db.Decimal(18, 4)
  currency    String
  status      String   @default("draft")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([projectId, status])
}

model CustomerProduct {
  id               String   @id
  customerId       String
  customer         Organization @relation(fields: [customerId], references: [id])
  projectId        String
  project          Project  @relation(fields: [projectId], references: [id])
  productName      String
  version          String
  installationDate DateTime
  status           String   @default("active")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  maintenanceCases MaintenanceCase[]

  @@unique([customerId, projectId, productName, version])
  @@index([customerId, status])
}

model MaintenanceCase {
  id          String   @id
  customerId  String
  customer    Organization @relation(fields: [customerId], references: [id])
  productId   String
  product     CustomerProduct @relation(fields: [productId], references: [id])
  description String
  priority    String
  status      String   @default("open")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([customerId, status])
  @@index([productId, status])
}

model SolutionProposal {
  id             String   @id
  customerId     String
  customer       Organization @relation(fields: [customerId], references: [id])
  description    String
  sourceEvidence Json
  estimatedValue Decimal? @db.Decimal(18, 4)
  currency       String?
  status         String   @default("proposed")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([customerId, status])
}
