{
  "compilerOptions": {
    "target": "ES2021",
    "module": "commonjs",
    "lib": ["ES2021"],
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "declaration": true,
    "sourceMap": true,
    "baseUrl": "../../",
    "paths": {
      "@aios/ai-core": ["packages/ai-core/dist/index"],
      "@aios/knowledge-graph": ["packages/knowledge-graph/dist/index"],
      "@aios/mcp-adapters": ["packages/mcp-adapters/dist/index"],
      "@aios/orchestrator": ["packages/orchestrator/dist/index"],
      "@aios/self-evolution": ["packages/self-evolution/dist/index"]
    }
  },
  "include": ["src/**/*.ts"]
}
