{
  "compilerOptions": {
    "target": "es2021",
    "module": "commonjs",
    "lib": ["es2021", "dom"],
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "moduleResolution": "node",
    "declaration": true,
    "declarationMap": true,
    "baseUrl": "../../", // Set baseUrl to the workspace root: /home/ubuntu/aios
    "paths": {
      "@aios/ai-core/*": ["packages/ai-core/dist/*"],
      "aios-mcp-adapters": ["packages/mcp-adapters/dist/index"],
      "aios-mcp-adapters/*": ["packages/mcp-adapters/dist/*"],
      "aios-knowledge-graph": ["packages/knowledge-graph/dist/index"],
      "aios-knowledge-graph/*": ["packages/knowledge-graph/dist/*"],
      "@aios/self-evolution": ["packages/self-evolution/dist/index"],
      "@aios/self-evolution/*": ["packages/self-evolution/dist/*"],
      "@aios/orchestrator/*": ["packages/orchestrator/src/*"]
    }
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "**/*.spec.ts"]
}
