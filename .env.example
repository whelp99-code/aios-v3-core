# Hybrid AI Core — copy to .env and fill secrets
RAPID_MLX_BASE_URL=http://localhost:8000/v1
AIOS_ENGINE_MODE=auto

# Cloud provider when AIOS_ENGINE_MODE=cloud (default: mimo)
AIOS_CLOUD_PROVIDER=mimo
MIMO_API_KEY=
MIMO_BASE_URL=https://api.xiaomimimo.com/v1
# MIMO_SKIP_HEALTH_PING=1

# Google Gemini (AI Studio API key — not bundled with Google AI Pro subscription)
GEMINI_API_KEY=
# GOOGLE_API_KEY=
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
# GEMINI_SKIP_HEALTH_PING=1

OPENAI_API_KEY=
ANTHROPIC_API_KEY=
HF_TOKEN=
