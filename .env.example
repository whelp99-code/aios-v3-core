# F-aios-v3 Server Configuration

# Server
PORT=3201
API_KEY=your-api-key-here
API_ACTOR_ID=local-operator
API_ACTOR_ROLES=operator

# Canonical PostgreSQL
DATABASE_URL=postgresql://aios:aios@localhost:5432/aios?schema=public
TEST_DATABASE_URL=postgresql://aios:aios@localhost:5432/aios_test?schema=public

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:3200,http://localhost:3201

# AI Engine
AI_ENGINE_MODE=auto
AI_SECURITY_LEVEL=cloud_secure

# LM Studio (Local)
LM_STUDIO_URL=http://localhost:1234/v1

# Mimo Cloud (Optional)
MIMO_API_KEY=
MIMO_BASE_URL=
MIMO_PROVIDER=together

# OpenAI (Optional)
OPENAI_API_KEY=

# Anthropic (Optional)
ANTHROPIC_API_KEY=

# HuggingFace (Optional)
HUGGINGFACE_API_KEY=

# LightRAG
LIGHTRAG_SERVER_URL=http://localhost:3300

# Mail Intelligence Portal Bridge
MAIL_INTELLIGENCE_URL=http://localhost:3301

# Langfuse (Optional)
LANGFUSE_SECRET_KEY=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_HOST=http://localhost:3000
